@using WarehouseManagementSystem.Models.WebApi
@model PagedResult<RcsEcsTask>
<style>
        /* 自定义样式 */
        .table th {
            white-space: nowrap;
        }
        
        /* 移动端优化 */
        @@media (max-width: 768px) {
            .pagination {
                font-size: 0.875rem;
            }
            .table {
                font-size: 0.875rem;
            }
        }
        
        /* 工具提示美化 */
        .tooltip-inner {
            max-width: 300px;
            text-align: left;
        }

    .container-fluid {
        height: 100%;
        display: contents;
        align-items: center;
    }
    </style>
<div class="container-fluid mt-4">
    <div class="card">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">接口任务列表</h5>
            <span class="badge bg-light text-primary">总记录数：@Model.TotalItems</span>
        </div>

        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover">
                    <thead class="table-light">
                        <tr>
                            <th>请求编号</th>
                            <th>任务编号</th>
                            <th class="d-none d-md-table-cell">任务状态</th>
                            <th class="d-none d-md-table-cell">创建时间</th>
                            <th class="d-none d-lg-table-cell">更新时间</th>
                            <th>执行状态</th>
                            <th class="d-none d-lg-table-cell">执行结果</th>
                            <th>重试次数</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Items)
                        {
                            <tr>
                                <td>@item.RequestCode</td>
                                <td>@item.TaskCode</td>
                                <td class="d-none d-md-table-cell">
                                    @{
                                        var statusClass = item.TaskStatus switch
                                        {
                                            0 => "bg-warning",
                                            1 => "bg-success",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @statusClass">@item.TaskStatus</span>
                                </td>
                                <td class="d-none d-md-table-cell">@item.CreateTime.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="d-none d-lg-table-cell">@(item.UpdateTime?.ToString("yyyy-MM-dd HH:mm") ?? "-")</td>
                                <td>
                                    <span class="badge @(item.Execute ? "bg-success" : "bg-warning")">
                                        @(item.Execute ? "已执行" : "未执行")
                                    </span>
                                </td>
                                <td class="d-none d-lg-table-cell">
                                    <button type="button" class="btn btn-sm btn-outline-info"
                                            data-bs-toggle="tooltip"
                                            title="@(string.IsNullOrEmpty(item.ExecuteResult) ? "无" : item.ExecuteResult)">
                                        查看结果
                                    </button>
                                </td>
                                <td>
                                    <span class="badge @(item.RetryCount > 0 ? "bg-danger" : "bg-success")">
                                        @item.RetryCount
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            @if (!Model.Items.Any())
            {
                <div class="text-center text-muted my-4">
                    <i class="fas fa-inbox fa-3x mb-3"></i>
                    <p>暂无任务数据</p>
                </div>
            }

            <div class="d-flex justify-content-between align-items-center flex-wrap mt-3">
                <div class="mb-2 mb-md-0">
                    <small class="text-muted">
                        当前第 @Model.PageNumber 页，共 @Model.TotalPages 页
                    </small>
                </div>

                <nav aria-label="Page navigation">
                    <ul class="pagination mb-0">
                        @if (Model.HasPreviousPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { page = Model.PageNumber - 1 })" aria-label="Previous">
                                    <span aria-hidden="true">&laquo;</span>
                                </a>
                            </li>
                        }

                        @for (int i = Math.Max(1, Model.PageNumber - 2); i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                            </li>
                        }

                        @if (Model.HasNextPage)
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { page = Model.PageNumber + 1 })" aria-label="Next">
                                    <span aria-hidden="true">&raquo;</span>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // 初始化所有工具提示
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });

            // 自动隐藏工具提示
            $('[data-bs-toggle="tooltip"]').on('click', function () {
                var tooltip = bootstrap.Tooltip.getInstance(this);
                if (tooltip) {
                    tooltip.hide();
                }
            });
        });
    </script>
}