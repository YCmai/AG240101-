
<div class="row mb-3" style="margin-top:1%">
    <div class="col-sm-8 col-12">
        <form asp-action="Index" method="get" class="d-flex">
            <input type="text" name="searchString" value="@ViewData["searchString"]" class="form-control me-2" placeholder="请输入库位点描述" />
            <button type="submit" style="width: 5em;" class="btn btn-primary me-2">搜索</button>
        </form>
    </div>
    <div class="col-sm-4 col-12 text-end mt-sm-0 mt-2">
        <a asp-action="CreateEdit" class="btn btn-success">新建库位</a>
    </div>
    <!-- 显示统计值 -->
   @*  <div class="row mb-3">
        <div class="col-sm-6 col-12">
            <p><strong>Storage Capacity Available:</strong> @ViewData["StorageCapacityAvailable"]</p>
        </div>
        <div class="col-sm-6 col-12">
            <p><strong>Storage Capacity Use:</strong> @ViewData["StorageCapacityUse"]</p>
        </div>
    </div> *@

</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered text-center">
        <thead class="table-light">
            <tr>
                <th>地图节点</th>
                <th>节点备注</th>
                <th>数量</th>
              @*   <th>物料编号</th> *@
                <th>操作点</th>
               @*  <th>托盘ID</th>
                <th>物料重量</th> *@
              @*   <th>物料数量</th> *@
                <th>举升高度</th>
                <th>卸货高度</th>
                <th>入库日期</th>
                <th>分组</th>
                <th>锁定</th>
                <th>操作</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model.Items)
            {
                @* 检查是否为异常物料行 *@
                var isErrorRow = item.MaterialCode != null && item.MaterialCode.Contains("Err_");
                <tr class="@(isErrorRow ? "bg-danger bg-opacity-10" : "")">
                    <td>@item.Name</td>
                    <td>@item.NodeRemark</td>
                    <th>@item.Quanitity</th>
                   @*  <td>@item.MaterialCode</td> *@
                    <td>@item.WattingNode</td>
                 @*    <td>@item.PalletID</td>
                    <td>@item.Weight</td>
                    <td>@item.Quanitity</td> *@
                    <td>@item.LiftingHeight</td>
                    <td>@item.UnloadHeight</td>
                    <td>@item.EntryDate</td>
                    <td>@item.Group</td>
                    <td>@item.Lock</td>
                    <td class="text-left">
                        <a asp-action="CreateEdit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                            <i class="fas fa-edit"></i> 编辑
                        </a>
                        <a href="javascript:void(0);" data-bs-toggle="modal" data-bs-target="#deleteModal" 
                           onclick="setDeleteInfo('@item.Id', '@item.Name',1)" class="btn btn-sm btn-danger">
                            <i class="fas fa-trash"></i> 删除
                        </a>
                        <a href="javascript:void(0);" data-bs-toggle="modal" data-bs-target="#deleteModal" 
                           onclick="setDeleteInfo('@item.Id', '@item.Name',2)" class="btn btn-sm btn-warning">
                            <i class="fas fa-unlock"></i> 重置锁定状态
                        </a>
                        <a href="javascript:void(0);" data-bs-toggle="modal" data-bs-target="#deleteModal" 
                           onclick="setDeleteInfo('@item.Id', '@item.Name',3)" class="btn btn-sm btn-danger">
                            <i class="fas fa-times"></i> 清空
                        </a>
                       @*  @if (isErrorRow)
                        {
                            <a href="javascript:void(0);" data-bs-toggle="modal" data-bs-target="#deleteModal" 
                               onclick="setDeleteInfo('@item.Id', '@item.Name',4)" class="btn btn-sm btn-info">
                                <i class="fas fa-redo"></i> 重置
                            </a>
                        } *@
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<!-- 分页导航，右下角显示 -->
<div class="d-flex justify-content-end">
    <nav aria-label="Page navigation">
        <ul class="pagination pagination-sm">
             @if (Model.HasPreviousPage)
            { 
                <li class="page-item">
                    <a class="page-link" href="?page=@(Model.PageNumber - 1)&searchString=@(ViewData["searchString"])">上一页</a>
                </li>
             } 

            <li class="page-item disabled">
                <span class="page-link">当前页: @Model.PageNumber / @Model.TotalPages</span>
            </li>

            @if (Model.HasNextPage)
            { 
                <li class="page-item">
                    <a class="page-link" href="?page=@(Model.PageNumber + 1)&searchString=@(ViewData["searchString"])">下一页</a>
                </li>
             } 
        </ul>
    </nav>
</div>
<!-- 消息模态框 -->
<div class="modal fade" id="messageModal" tabindex="-1" aria-labelledby="messageModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content shadow-lg border-0">
            <div class="modal-header bg-@(TempData["MessageType"]?.ToString().ToLower()) text-white">
                <h5 class="modal-title" id="messageModalLabel">
                    <i class="bi bi-check-circle me-2"></i>Prompt
                </h5>
                <!-- 修复关闭按钮的样式问题 -->
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close" style="filter: invert(1);"></button>
            </div>
            <div class="modal-body text-center p-4">
                <p class="lead">@TempData["Message"]</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="closebtn" data-bs-dismiss="modal">关闭</button>
            </div>
        </div>
    </div>
</div>




<!-- 删除确认模态框 -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="deleteModalLabel">确认框</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <!-- 内容将由 JavaScript 动态设置 -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-danger" id="confirmDeleteButton">确认</button>
            </div>
        </div>
    </div>
</div>


<script>
    // 首先修改 setDeleteInfo 函数，添加操作类型的判断
    function setDeleteInfo(id, name, type) {
        const modalTitle = document.getElementById('deleteModalLabel');
        const modalBody = document.querySelector('#deleteModal .modal-body');
        const confirmButton = document.getElementById('confirmDeleteButton');
        
        window.deleteId = id;
        window.locationtype = type;

        let operationText = '';
        switch (type) {
            case 1:
                operationText = "删除";
                modalTitle.textContent = "删除确认";
                confirmButton.className = "btn btn-danger";
                break;
            case 2:
                operationText = "解锁";
                modalTitle.textContent = "解锁确认";
                confirmButton.className = "btn btn-warning";
                break;
            case 3:
                operationText = "删除物料";
                modalTitle.textContent = "清空确认";
                confirmButton.className = "btn btn-danger";
                break;
            case 4:
                operationText = "重置异常物料";
                modalTitle.textContent = "重置确认";
                confirmButton.className = "btn btn-info";
                break;
        }

        modalBody.innerHTML = `是否确认对库位 <strong>"${name}"</strong> 执行${operationText}操作？`;
    }

    // 修改确认按钮的处理逻辑
    $(document).ready(function () {
        let deleteId;
        let locationtype;

        window.setDeleteInfo = setDeleteInfo; // 将函数暴露到全局

        $('#confirmDeleteButton').click(function () {
            $('#deleteModal').modal('hide');
            // 调试输出，查看 deleteId 和 locationtype 的值
            console.log("deleteId:", window.deleteId);
            console.log("locationtype:", window.locationtype);
            // 根据操作类型设置提示信息
            let operationText = '';
            switch (locationtype) {
                case 1:
                    operationText = "删除";
                    break;
                case 2:
                    operationText = "重置锁定状态";
                    break;
                case 3:
                    operationText = "删除物料";
                    break;
                case 4:
                    operationText = "重置异常物料";
                    break;
            }
          
            $.ajax({
                url: '@Url.Action("DeleteConfirmed", "Location")',
                type: 'POST',
                data: {
                    Id: window.deleteId,
                    Type: window.locationtype,
                    __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                },
                success: function (response) {
                    // 设置消息和类型
                    $('#messageModal .modal-body').text(response.message);
                    $('#messageModal .modal-header')
                        .removeClass('bg-success bg-danger')
                        .addClass(response.success ? 'bg-success' : 'bg-danger');

                    // 显示消息模态框
                    $('#messageModal').modal('show');

                    // 设置自动关闭并跳转
                    setTimeout(function () {
                        $('#messageModal').modal('hide');
                        window.location.href = '@Url.Action("Index", "Location")';
                    }, 2000);
                },
                error: function () {
                    $('#messageModal .modal-body').text(`${operationText}操作失败，请稍后再试。`);
                    $('#messageModal .modal-header')
                        .removeClass('bg-success bg-danger')
                        .addClass('bg-danger');
                    $('#messageModal').modal('show');
                }
            });
        });

        // 当用户手动关闭消息模态框时跳转
        $('#messageModal').on('hidden.bs.modal', function () {
            window.location.href = '@Url.Action("Index", "Location")';
        });
    });
</script>



