@using WarehouseManagementSystem.Models.PLC
@{
    ViewData["Title"] = "PLC监控";
}

<style>
  

    /* 适配不同屏幕大小 */
    @@media (max-width: 768px) {
        .position-fixed {
            position: static !important;
            left: 0 !important;
            width: 100% !important;
        }

        body {
            padding-top: 0;
        }
    }

    /* 优化卡片样式 */
    .card {
        border: 1px solid #e0e0e0;
        border-radius: 0.5rem;
        margin-bottom: 1rem;
        transition: box-shadow 0.3s;
        min-height: 150px; /* 设置最小高度，防止内容变化导致高度变化 */
    }

    .card:hover {
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .card-header {
        background-color: #007bff;
        color: white;
        font-weight: bold;
        text-align: center; /* 中心对齐 */
    }

    .current-value {
        display: inline-block;
        min-width: auto; /* 移除最小宽度限制 */
        width: auto; /* 根据内容自动调整宽度 */
        padding: 0.25rem 0.5rem; /* 添加一些内边距 */
        text-align: center;
        white-space: normal; /* 允许文本换行 */
        word-break: break-word; /* 长单词可以换行 */
    }

    /* 为长文本徽章添加最大宽度 */
    .current-value.long-text {
        max-width: 100%; /* 最大宽度为父容器的100% */
    }

    /* 统一标题样式 */
    .signal-title {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem;
        border-bottom: 1px solid #e0e0e0;
    }

    .signal-title h6 {
        margin: 0;
        flex-grow: 1; /* 使标题占据剩余空间 */
        text-align: left; /* 左对齐 */
        color: black; /* 设置字体颜色为黑色 */
    }

    .signal-title small {
        font-size: 0.8rem;
        color: #6c757d; /* 灰色 */
    }

    /* 按钮样式 */
    .btn-group .btn {
        flex: 1; /* 按钮均匀分布 */
    }

    .fixed-width {
        width: 150px; /* 设置固定宽度 */
        white-space: nowrap; /* 防止文本换行 */
        overflow: hidden; /* 隐藏超出部分 */
        text-overflow: ellipsis; /* 超出部分显示省略号 */
    }

    .card-body {
        min-height: 100px; /* 设置最小高度 */
    }

    /* 修复布局跳动问题 */
    .col-md-2 {
        height: auto;
        margin-bottom: 15px;
    }

    /* 使用骨架屏技术，在数据加载前显示占位符 */
    .skeleton-loading {
        position: relative;
        overflow: hidden;
        background: #f0f0f0;
        border-radius: 4px;
    }
    
    .skeleton-loading::after {
        content: "";
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent);
        animation: skeleton-loading 1.5s infinite;
    }
    
    @@keyframes skeleton-loading {
        0% { transform: translateX(-100%); }
        100% { transform: translateX(100%); }
    }

    /* 优化页面布局 */
    .plc-monitor-container {
        padding-top: 10px; /* 减少顶部空白 */
        margin-bottom: var(--footer-height); /* 为页脚留出空间 */
    }
    
    /* 左侧说明文档卡片 - 固定在页面中间 */
    .sidebar-card {
        position: fixed;
        top: 50%;
        transform: translateY(-50%);
        width: calc(16.666% - 20px); /* col-md-2 的宽度减去一些边距 */
        max-height: 80vh;
        overflow-y: auto;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        z-index: 1000; /* 确保在其他内容之上 */
    }
    
    /* 确保左右内容对齐 */
    .row {
        margin-left: 0;
        margin-right: 0;
    }
    
    .col-md-2, .col-md-10 {
        padding-left: 10px;
        padding-right: 10px;
    }
    
    /* 内容卡片样式 */
    .plc-card {
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.08);
        margin-bottom: 15px;
    }
    
    .plc-card-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 15px;
        background-color: #f8f9fa;
        border-bottom: 1px solid #e9ecef;
        border-radius: 8px 8px 0 0;
    }
    
    .plc-card-body {
        padding: 15px;
    }
    
    /* 加载指示器居中 */
    #loadingIndicator {
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        min-height: 200px;
    }
    
    /* 滚动条美化 */
    .sidebar-card::-webkit-scrollbar {
        width: 6px;
    }
    
    .sidebar-card::-webkit-scrollbar-track {
        background: #f1f1f1;
    }
    
    .sidebar-card::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 3px;
    }
    
    .sidebar-card::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }

  
</style>

<div>
    <div class="row">
        <!-- 左侧说明文档 -->
        <div class="col-md-2">
            <div class="card sidebar-card">
                <div class="card-header bg-primary text-white py-2">
                    <h6 class="mb-0">信号说明</h6>
                </div>
                <div class="card-body p-2">
                    <div class="mb-2">
                        <h6 class="text-primary mb-1">电镀线</h6>
                        <div class="small">
                            <p class="mb-1"><strong>PLC寄存器:</strong></p>
                            <ul class="list-unstyled ms-1 mb-1" style="font-size: 0.8rem;">
                                <li>X1-X4: 呼叫AGV</li>
                                <li>N1-N4: 允许进入</li>
                                <li>F1-F4: 允许放料</li>
                                <li>T1-T4: 允许离开</li>
                            </ul>
                            <p class="mb-1"><strong>AGV寄存器:</strong></p>
                            <ul class="list-unstyled ms-1" style="font-size: 0.8rem;">
                                <li>Y1-Y4: 应答回应</li>
                                <li>NG1-NG4: 应答失败</li>
                                <li>M1-M4: 到达外围</li>
                                <li>E1-E4: 到达工位</li>
                                <li>K1-K4: 放料完成</li>
                            </ul>
                        </div>
                    </div>
                    <div>
                        <h6 class="text-primary mb-1">总装线</h6>
                        <div class="small">
                            <p class="mb-1"><strong>PLC寄存器:</strong></p>
                            <ul class="list-unstyled ms-1 mb-1" style="font-size: 0.8rem;">
                                <li>X1-X3: 呼叫AGV</li>
                                <li>N1-N3: 允许进入</li>
                                <li>F1-F3: 允许放料</li>
                                <li>T1-T3: 允许离开</li>
                            </ul>
                            <p class="mb-1"><strong>AGV寄存器:</strong></p>
                            <ul class="list-unstyled ms-1" style="font-size: 0.8rem;">
                                <li>Y1-Y3: 应答回应</li>
                                <li>NG1-NG3: 应答失败</li>
                                <li>M1-M3: 到达外围</li>
                                <li>E1-E3: 到达工位</li>
                                <li>K1-K3: 放料完成</li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- 右侧PLC状态显示 -->
        <div class="col-md-10">
            <!-- 数据显示区域 -->
            <div class="row g-2" id="plcDataContainer">
                <!-- 显示加载中状态 -->
                <div class="col-12 text-center" id="loadingIndicator">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">加载中...</span>
                    </div>
                    <p class="mt-2">正在加载数据...</p>
                </div>
            </div>
            
            <!-- 分页区域 -->
            <div class="d-flex justify-content-between align-items-center mt-2" id="paginationContainer">
                <!-- 分页将通过AJAX填充 -->
            </div>
        </div>
    </div>
</div>

<!-- 写入值模态框 -->
<div class="modal fade" id="writeValueModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header py-2">
                <h5 class="modal-title">写入值</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">地址：<span id="addressDisplay"></span></label>
                    <select class="form-select" id="valueSelect">
                        <option value="">请选择值</option>
                    </select>
                </div>
            </div>
            <div class="modal-footer py-1">
                <button type="button" class="btn btn-secondary btn-sm" data-bs-dismiss="modal">取消</button>
                <button type="button" class="btn btn-primary btn-sm" id="confirmWrite">确定</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let currentPage = 1; // 默认从第一页开始
        let currentGroup = '';
        let isLoading = false;
        const pageSize = 10; // 设置默认页面大小

        // 页面加载完成后立即通过AJAX加载数据
        $(document).ready(function() {
            // 从URL获取参数
            const urlParams = new URLSearchParams(window.location.search);
            const pageParam = urlParams.get('pageNumber');
            const groupParam = urlParams.get('group');
            
            if (pageParam) {
                currentPage = parseInt(pageParam);
            }
            
            if (groupParam) {
                currentGroup = groupParam;
                $('#groupFilter').val(groupParam);
            }
            
            // 立即加载数据
            changePage(currentPage);
            
            // 绑定事件
            bindEvents();
            
            // 设置自动刷新
            setTimeout(autoRefresh, 1000);
        });

        function changePage(newPageNumber) {
            if (isLoading) return;
            isLoading = true;
            currentPage = newPageNumber;

            $.ajax({
                url: '/PlcMonitor/GetLatestData',
                type: 'GET',
                data: {
                    pageNumber: currentPage,
                    pageSize: pageSize,
                    groupName: currentGroup
                },
                success: function (result) {
                    if (result.success) {
                        // 更新URL
                        const urlParams = new URLSearchParams();
                        urlParams.set('pageNumber', currentPage);
                        urlParams.set('pageSize', pageSize);
                        if (currentGroup) {
                            urlParams.set('group', currentGroup);
                        }
                        window.history.pushState(
                            {}, 
                            '', 
                            `/PlcMonitor/Index?${urlParams.toString()}`
                        );
                        
                        // 更新内容
                        if (result.data && Array.isArray(result.data)) {
                            updateUI(result.data);
                            if (result.pagination) {
                                updatePagination(result.pagination);
                            }
                        }
                    } else {
                        alert('获取数据失败：' + (result.message || '未知错误'));
                    }
                },
                error: function (xhr, status, error) {
                    console.error('Ajax error:', error);
                    alert('获取数据失败，请重试');
                },
                complete: function () {
                    isLoading = false;
                    $('#loadingIndicator').hide();
                }
            });
        }

        function updateUI(data) {
            let html = '';
            
            // 如果没有数据，保持原有结构但显示占位符
            if (!data || data.length === 0) {
                $('#loadingIndicator').html(`
                    <div class="alert alert-info">
                        <i class="fas fa-info-circle me-2"></i>没有找到数据
                    </div>
                `);
                return;
            }
            
            // 隐藏加载指示器
            $('#loadingIndicator').hide();
            
            data.forEach(function(group) {
                html += `
                    <div class="col-12">
                        <div class="plc-card">
                            <div class="plc-card-header">
                                <h6 class="mb-0">${group.groupName}</h6>
                                <small class="text-muted">${new Date().toLocaleTimeString()}</small>
                            </div>
                            <div class="plc-card-body">
                                <div class="row g-2">`;
                
                group.items.forEach(function(item) {
                    const nameParts = item.name.split('-');
                    // 检查值的长度，为长文本添加额外的类
                    const isLongText = item.currentValue && item.currentValue.length > 15;
                    const valueClass = isLongText ? 'long-text' : '';
                    
                    // 提取基本名称，去除可能的描述文本
                    let cleanName = item.name;
                    if (cleanName.includes('-')) {
                        const parts = cleanName.split('-');
                        if (parts.length >= 2) {
                            cleanName = parts[0] + '-' + parts[1]; // 只保留前两部分，例如 "电镀线-1"
                        }
                    }
                    
                    html += `
                        <div class="col-md-2">
                            <div class="card h-100" data-address="${item.address}">
                                <div class="card-body p-2">
                                    <div class="small">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span class="fixed-width">${nameParts[1] || ''}</span>
                                            <span class="badge bg-secondary">${item.stationNumber || ''}</span>
                                        </div>
                                        <div class="row g-1">
                                            <div class="col-12">
                                                <small class="text-muted">${item.address || ''}</small>
                                            </div>
                                            <div class="col-12">
                                                <span class="badge ${item.currentValue && item.currentValue.includes('null') ? 'bg-secondary' : 'bg-danger'} current-value ${valueClass}" 
                                                      data-old-value="${item.currentValue || ''}">
                                                    ${item.currentValue || ''}
                                                </span>
                                            </div>
                                            <div class="col-12">
                                                <small class="text-muted">更新: ${item.updateTime || '无'}</small>
                                            </div>
                                        </div>
                                        <div class="btn-group btn-group-sm w-100 mt-1">
                                            <button class="btn btn-outline-primary py-0 write-value"
                                                    data-bs-toggle="modal"
                                                    data-bs-target="#writeValueModal"
                                                    data-address-id="${item.id || ''}"
                                                    data-address-name="${cleanName}"
                                                    data-address="${item.address || ''}">
                                                <i class="fas fa-edit"></i>
                                            </button>
                                            <button class="btn btn-outline-warning py-0 reset-signal"
                                                    data-address-id="${item.id || ''}"
                                                    data-address-name="${cleanName}"
                                                    data-address="${item.address || ''}">
                                                <i class="fas fa-undo"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>`;
                });
                
                html += `
                        </div>
                    </div>
                </div>
            </div>`;
            });
            
            // 更新内容
            $('#plcDataContainer').html(html);
            
            // 确保绑定事件
            bindEvents();
        }

        function updatePagination(pagination) {
            let html = '';
            
            if (pagination.totalPages > 1) {
                html += `
                    <div>
                        <span>共 ${pagination.totalItems} 条记录，每页 ${pagination.pageSize} 条</span>
                    </div>
                    <ul class="pagination pagination-sm mb-0">`;
                
                // 首页和上一页
                html += `
                    <li class="page-item ${pagination.hasPreviousPage ? '' : 'disabled'}">
                        <a class="page-link" href="javascript:void(0)" onclick="changePage(1)">
                            <i class="fas fa-angle-double-left"></i>
                        </a>
                    </li>
                    <li class="page-item ${pagination.hasPreviousPage ? '' : 'disabled'}">
                        <a class="page-link" href="javascript:void(0)" onclick="changePage(${pagination.pageNumber - 1})">
                            <i class="fas fa-angle-left"></i>
                        </a>
                    </li>`;
                
                // 页码
                for (let i = Math.max(1, pagination.pageNumber - 2); i <= Math.min(pagination.totalPages, pagination.pageNumber + 2); i++) {
                    html += `
                        <li class="page-item ${i === pagination.pageNumber ? 'active' : ''}">
                            <a class="page-link" href="javascript:void(0)" onclick="changePage(${i})">${i}</a>
                        </li>`;
                }
                
                // 下一页和末页
                html += `
                    <li class="page-item ${pagination.hasNextPage ? '' : 'disabled'}">
                        <a class="page-link" href="javascript:void(0)" onclick="changePage(${pagination.pageNumber + 1})">
                            <i class="fas fa-angle-right"></i>
                        </a>
                    </li>
                    <li class="page-item ${pagination.hasNextPage ? '' : 'disabled'}">
                        <a class="page-link" href="javascript:void(0)" onclick="changePage(${pagination.totalPages})">
                            <i class="fas fa-angle-double-right"></i>
                        </a>
                    </li>`;
                
                html += '</ul>';
            }
            
            $('#paginationContainer').html(html);
        }

        function bindEvents() {
            // 写入值按钮点击事件
            $(document).off('click', '.write-value').on('click', '.write-value', function() {
                const addressId = $(this).data('address-id');
                const addressName = $(this).data('address-name');
                const address = $(this).data('address');
                
                console.log('打开写入值模态框:', addressId, addressName, address); // 添加调试日志
                
                $('#addressDisplay').text(addressName + ' (' + address + ')');
                $('#valueSelect').empty().append('<option value="">请选择值</option>');
                
                // 获取工位号 - 修复从地址名称中提取工位号的逻辑
                let stationNumber = '';
                if (addressName.includes('电镀线') || addressName.includes('总装线')) {
                    // 从地址中提取数字
                    if (address.includes('DM30100')) stationNumber = '1';
                    else if (address.includes('DM30200')) stationNumber = '1';
                    else if (address.includes('DM30300')) stationNumber = '2';
                    else if (address.includes('DM30400')) stationNumber = '2';
                    else if (address.includes('DM30500')) stationNumber = '3';
                    else if (address.includes('DM30600')) stationNumber = '3';
                    else if (address.includes('DM30700')) stationNumber = '4';
                    else if (address.includes('DM30800')) stationNumber = '4';
                }
                
                console.log('工位号:', stationNumber); // 添加调试日志
                
                // 根据地址类型添加不同的选项
                if (addressName.includes('电镀线')) {
                    if (address.includes('DM30100') || address.includes('DM30300') || 
                        address.includes('DM30500') || address.includes('DM30700')) {
                        // PLC写入寄存器
                        $('#valueSelect').append(`<option value="X${stationNumber}">X${stationNumber} - 呼叫AGV</option>`);
                        $('#valueSelect').append(`<option value="N${stationNumber}">N${stationNumber} - 允许进入</option>`);
                        $('#valueSelect').append(`<option value="F${stationNumber}">F${stationNumber} - 允许放料</option>`);
                        $('#valueSelect').append(`<option value="T${stationNumber}">T${stationNumber} - 允许离开</option>`);
                        $('#valueSelect').append(`<option value="null">null - 清空</option>`);
                    } else if (address.includes('DM30200') || address.includes('DM30400') || 
                               address.includes('DM30600') || address.includes('DM30800')) {
                        // AGV写入寄存器
                        $('#valueSelect').append(`<option value="Y${stationNumber}">Y${stationNumber} - 应答回应</option>`);
                        $('#valueSelect').append(`<option value="NG${stationNumber}">NG${stationNumber} - 应答失败</option>`);
                        $('#valueSelect').append(`<option value="M${stationNumber}">M${stationNumber} - 到达外围</option>`);
                        $('#valueSelect').append(`<option value="E${stationNumber}">E${stationNumber} - 到达工位</option>`);
                        $('#valueSelect').append(`<option value="K${stationNumber}">K${stationNumber} - 放料完成</option>`);
                        $('#valueSelect').append(`<option value="null">null - 清空</option>`);
                    } else if (address.includes('DM31000') || address.includes('DM32000')) {
                        // 直接输入值
                        $('#valueSelect').append(`<option value="null">null - 清空</option>`);
                    }
                } else if (addressName.includes('总装线')) {
                    if (address.includes('DM30100') || address.includes('DM30400') || address.includes('DM30700')) {
                        // PLC写入寄存器
                        $('#valueSelect').append(`<option value="X${stationNumber}">X${stationNumber} - 呼叫AGV</option>`);
                        $('#valueSelect').append(`<option value="N${stationNumber}">N${stationNumber} - 允许进入</option>`);
                        $('#valueSelect').append(`<option value="F${stationNumber}">F${stationNumber} - 允许放料</option>`);
                        $('#valueSelect').append(`<option value="T${stationNumber}">T${stationNumber} - 允许离开</option>`);
                        $('#valueSelect').append(`<option value="null">null - 清空</option>`);
                    } else if (address.includes('DM30200') || address.includes('DM30500') || address.includes('DM30800')) {
                        // AGV写入寄存器
                        $('#valueSelect').append(`<option value="Y${stationNumber}">Y${stationNumber} - 应答回应</option>`);
                        $('#valueSelect').append(`<option value="NG${stationNumber}">NG${stationNumber} - 应答失败</option>`);
                        $('#valueSelect').append(`<option value="M${stationNumber}">M${stationNumber} - 到达外围</option>`);
                        $('#valueSelect').append(`<option value="E${stationNumber}">E${stationNumber} - 到达工位</option>`);
                        $('#valueSelect').append(`<option value="K${stationNumber}">K${stationNumber} - 放料完成</option>`);
                        $('#valueSelect').append(`<option value="null">null - 清空</option>`);
                    } else if (address.includes('DM30300') || address.includes('DM30600')) {
                        // 直接输入值
                        $('#valueSelect').append(`<option value="null">null - 清空</option>`);
                    }
                }
                
                // 存储当前选中的地址ID
                $('#confirmWrite').data('address-id', addressId);
            });
            
            // 确认写入按钮点击事件
            $('#confirmWrite').off('click').on('click', function() {
                const addressId = $(this).data('address-id');
                const value = $('#valueSelect').val();
                
                console.log('确认写入:', addressId, value); // 添加调试日志
                
                if (!value) {
                    alert('请选择一个值');
                    return;
                }
                
                $.ajax({
                    url: '/PlcMonitor/WriteValue',
                    type: 'POST',
                    data: {
                        id: addressId,
                        value: value === 'null' ? null : value
                    },
                    success: function(result) {
                        console.log('写入结果:', result); // 添加调试日志
                        if (result.success) {
                            $('#writeValueModal').modal('hide');
                            // 立即刷新数据
                            changePage(currentPage);
                            alert('写入成功，等待信号变更');
                        } else {
                            alert('写入失败：' + (result.message || '未知错误'));
                        }
                    },
                    error: function(xhr, status, error) {
                        console.error('写入错误:', error); // 添加调试日志
                        alert('写入请求失败，请重试');
                    }
                });
            });
            
            // 重置信号按钮点击事件
            $(document).off('click', '.reset-signal').on('click', '.reset-signal', function() {
                const addressId = $(this).data('address-id');
                
                if (confirm('确定要重置此信号吗？')) {
                    $.ajax({
                        url: '/PlcMonitor/WriteValue',
                        type: 'POST',
                        data: {
                            id: addressId,
                            value: null
                        },
                        success: function(result) {
                            if (result.success) {
                                // 立即刷新数据
                                changePage(currentPage);
                            } else {
                                alert('重置失败：' + (result.message || '未知错误'));
                            }
                        },
                        error: function() {
                            alert('重置请求失败，请重试');
                        }
                    });
                }
            });
        }

        // 自动刷新函数
        let refreshTimeout;
        function autoRefresh() {
            clearTimeout(refreshTimeout);
            
            if (!isLoading && !$('#writeValueModal').hasClass('show')) {
                changePage(currentPage);
            }
            
            refreshTimeout = setTimeout(autoRefresh, 1000);
        }
    </script>
}