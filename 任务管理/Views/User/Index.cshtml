@model List<WarehouseManagementSystem.Models.User>

@{
    ViewData["Title"] = "用户管理";
}

<div>
    <div class="row mb-3">
        <div class="col">
            <h2>用户管理</h2>
        </div>
        <div class="col text-end">
            <a href="@Url.Action("Create")" class="btn btn-primary">
                <i class="fas fa-plus"></i> 新建用户
            </a>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-bordered">
            <thead class="table-light">
                <tr>
                    <th>用户名</th>
                    <th>角色</th>
                    <th>允许操作的任务类型</th>
                    <th>创建时间</th>
                    <th>最后登录时间</th>
                    <th>状态</th>
                    <th>操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>@user.Username</td>
                        <td>
                            @switch (user.Role)
                            {
                                case UserRole.Viewer:
                                    <span class="badge bg-secondary">查看者</span>
                                    break;
                                case UserRole.Operator:
                                    <span class="badge bg-primary">操作员</span>
                                    break;
                                case UserRole.Supervisor:
                                    <span class="badge bg-info">主管</span>
                                    break;
                                case UserRole.Admin:
                                    <span class="badge bg-danger">管理员</span>
                                    break;
                            }
                        </td>
                        <td>
                            @if (user.Role == UserRole.Operator && !string.IsNullOrEmpty(user.AllowedTaskTypes))
                            {
                                var taskTypeInts = System.Text.Json.JsonSerializer.Deserialize<int[]>(user.AllowedTaskTypes);
                                foreach (var typeInt in taskTypeInts)
                                {
                                    var type = (RCS_UserTasks.TaskType)typeInt;
                                    <span class="badge bg-success me-1">@type.GetDisplayName()</span>
                                }
                            }
                            else if (user.Role == UserRole.Supervisor || user.Role == UserRole.Admin)
                            {
                                <span class="badge bg-success">所有类型</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">无</span>
                            }
                        </td>
                        <td>@user.CreateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@(user.LastLoginTime?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                        <td>
                            @if (user.IsActive)
                            {
                                <span class="badge bg-success">启用</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">禁用</span>
                            }
                        </td>
                        <td>
                            <div class="btn-group">
                                <a href="@Url.Action("Edit", new { id = user.Id })" class="btn btn-sm btn-primary">
                                    <i class="fas fa-edit"></i> 编辑
                                </a>
                                <button type="button" class="btn btn-sm btn-warning" onclick="toggleUserStatus(@user.Id)">
                                    <i class="fas fa-power-off"></i> @(user.IsActive ? "禁用" : "启用")
                                </button>
                                <button type="button" class="btn btn-sm btn-danger" onclick="deleteUser(@user.Id)">
                                    <i class="fas fa-trash"></i> 删除
                                </button>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script>
        function toggleUserStatus(userId) {
            if (confirm('确定要更改此用户的状态吗？')) {
                $.post('@Url.Action("ToggleActive")', { id: userId }, function(result) {
                    if (result.success) {
                        location.reload();
                    } else {
                        alert(result.message);
                    }
                });
            }
        }

        function deleteUser(userId) {
            if (confirm('确定要删除此用户吗？此操作不可恢复！')) {
                $.post('@Url.Action("Delete")', { id: userId }, function(result) {
                    if (result.success) {
                        location.reload();
                    } else {
                        alert(result.message);
                    }
                });
            }
        }
    </script>
} 