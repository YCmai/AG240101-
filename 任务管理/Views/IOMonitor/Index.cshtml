        // 更新信号UI的函数
        function updateSignalUI(ip, address, value, updateTime) {
            const statusElements = document.querySelectorAll(
                `.signal-value[data-ip="${ip}"][data-address="${address}"]`
            );
            
            const timeElements = document.querySelectorAll(
                `.signal-update-time[data-ip="${ip}"][data-address="${address}"]`
            );

            statusElements.forEach(element => {
                element.textContent = value ? 'ON' : 'OFF';
                element.className = `signal-value ${value ? 'on' : 'off'}`;
            });

            timeElements.forEach(element => {
                element.textContent = updateTime || new Date().toLocaleString('zh-CN', {
                    year: 'numeric',
                    month: '2-digit',
                    day: '2-digit',
                    hour: '2-digit',
                    minute: '2-digit',
                    second: '2-digit'
                });
            });
        }

        // 启动连接
        // startConnection();

        // 刷新任务列表
        async function refreshTasks() {
            // 如果已经在刷新中，直接返回
            if (isRefreshingTasks) {
                console.log("上一次任务刷新未完成，跳过本次刷新");
                return;
            }
            
            // 设置锁定状态
            isRefreshingTasks = true;
            
            try {
                console.log("开始刷新任务列表");
                const response = await fetch('/IOMonitor/GetIOTasks');
                if (!response.ok) {
                    throw new Error(`HTTP error! status: ${response.status}`);
                }

                const tasks = await response.json();
                
                // 更新任务计数徽章
                const taskCountElement = document.getElementById('taskCount');
                if (taskCountElement) {
                    taskCountElement.textContent = tasks.length;
                }
                
                // 更新任务表格
                const taskTableBody = document.getElementById('taskTableBody');
                if (taskTableBody) {
                    // 清空当前表格内容
                    taskTableBody.innerHTML = '';
                    
                    // 添加任务行
                    for (const task of tasks) {
                        const row = document.createElement('tr');
                        
                        // 格式化日期
                        const createdTime = task.createdTime ? new Date(task.createdTime).toLocaleString('zh-CN') : '-';
                        const completedTime = task.completedTime ? new Date(task.completedTime).toLocaleString('zh-CN') : '-';
                        
                        // 设置状态样式
                        const statusClass = task.status < 30 ? 'pending' : 'completed';
                        const statusText = task.status < 30 ? '进行中' : '已完成';
                        
                        // 设置行内容
                        row.innerHTML = `
                            <td>${task.id}</td>
                            <td>${task.taskType || '-'}</td>
                            <td><span class="task-status ${statusClass}">${statusText}</span></td>
                            <td>${task.deviceIp || '-'}</td>
                            <td>${task.signalAddress || '-'}</td>
                            <td>${task.writeValue !== undefined ? (task.writeValue ? 'ON' : 'OFF') : '-'}</td>
                            <td>${createdTime}</td>
                            <td>${completedTime}</td>
                        `;
                        
                        taskTableBody.appendChild(row);
                    }
                }
                
                console.log("任务列表刷新完成");
            } catch (error) {
                console.error('刷新任务列表失败:', error);
            } finally {
                // 无论成功或失败，都解除锁定状态
                isRefreshingTasks = false;
            }
        }

        // 修改后的startSignalRefresh函数，增加任务刷新
        function startPeriodicRefresh(signalInterval = 3000, taskInterval = 5000) {
            // 信号刷新循环
            function scheduleNextSignalRefresh() {
                setTimeout(async () => {
                    await refreshSignals();
                    scheduleNextSignalRefresh(); // 完成后再安排下一次
                }, signalInterval);
            }
            
            // 任务刷新循环
            function scheduleNextTaskRefresh() {
                setTimeout(async () => {
                    await refreshTasks();
                    scheduleNextTaskRefresh(); // 完成后再安排下一次
                }, taskInterval);
            }
            
            // 初始调用
            scheduleNextSignalRefresh();
            scheduleNextTaskRefresh();
            
            console.log(`定时刷新已启动 - 信号: ${signalInterval}ms, 任务: ${taskInterval}ms`);
        }

        // 在页面加载完成后启动
        document.addEventListener('DOMContentLoaded', function() {
            startPeriodicRefresh(3000, 5000); // 信号3秒刷新一次，任务5秒刷新一次
        });
    </script>
