    <!-- 替换原来的图表部分为消息处理状态面板 -->
    <div class="col-12 col-lg-8 mb-3">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span>消息处理状态</span>
                <div class="d-flex align-items-center">
                    <select id="pageSizeSelect" class="form-select form-select-sm me-2" style="width: auto;">
                        <option value="10">10条/页</option>
                        <option value="20">20条/页</option>
                        <option value="50">50条/页</option>
                    </select>
                    <button class="btn btn-sm btn-outline-primary" onclick="refreshMessageStatus()">
                        <i class="bi bi-arrow-clockwise"></i> 刷新
                    </button>
                </div>
            </div>
            <div class="card-body">
                <!-- 状态统计卡片 -->
                <div class="row g-2 mb-3">
                    <!-- ... 状态统计卡片内容保持不变 ... -->
                </div>

                <!-- 消息处理列表 -->
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead>
                            <tr>
                                <th>时间</th>
                                <th>客户端</th>
                                <th>消息内容</th>
                                <th>状态</th>
                               
                            </tr>
                        </thead>
                        <tbody id="messageProcessTable">
                        </tbody>
                    </table>
                </div>

                <!-- 分页控件 -->
                <div class="d-flex justify-content-between align-items-center mt-3">
                    <div class="text-muted">
                        总共 <span id="totalRecords">0</span> 条记录
                    </div>
                    <nav aria-label="分页">
                        <ul class="pagination pagination-sm mb-0" id="pagination">
                        </ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4 mb-3">
        <div class="card">
            <div class="card-header">客户端状态</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>客户端</th>
                                <th>状态</th>
                                <th>消息数</th>
                            </tr>
                        </thead>
                        <tbody id="clientStatusTable">
                            @foreach (var status in Model.ClientStatuses)
                            {
                                <tr>
                                    <td class="text-truncate" style="max-width: 150px;">
                                        @status.ClientEndpoint
                                    </td>
                                    <td>
                                        <span class="badge status-badge @(status.IsConnected ? "bg-success" : "bg-danger")">
                                            @(status.IsConnected ? "在线" : "离线")
                                        </span>
                                    </td>
                                    <td>@status.MessageCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

